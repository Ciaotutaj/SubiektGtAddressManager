<Window x:Class="SubiektGtAddressManager.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie adresami kontrahentów — logowanie do Subiekta GT"
        Icon="/Assets/SubiektGtAddressManager.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        Width="560" SizeToContent="Height"
        MinWidth="480"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button x:Name="ThemeToggleButton" Content="Ciemny motyw" Padding="6,2" DockPanel.Dock="Right"
                    HorizontalAlignment="Right" Click="ThemeToggleButton_Click"/>
            <TextBlock Text="Połączenie z serwerem SQL" FontWeight="Bold" VerticalAlignment="Center"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Serwer:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Baza:" VerticalAlignment="Center"/>
            <ComboBox x:Name="DatabaseComboBox" Grid.Column="1" IsEditable="True" MinWidth="80"
                      Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding Databases}"/>
            <Button Grid.Column="2" Content="Pobierz bazy" Padding="6,2" Margin="6,0,0,0" Click="LoadDatabasesButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <RadioButton x:Name="WindowsAuthRadio" Content="Uwierzytelnianie Windows" GroupName="Auth"
                         IsChecked="{Binding UseWindowsAuthentication}" Margin="0,0,16,0"/>
            <RadioButton x:Name="SqlAuthRadio" Content="Uwierzytelnianie SQL Server" GroupName="Auth"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,0,0,4" IsEnabled="{Binding IsChecked, ElementName=SqlAuthRadio}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Login SQL:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding SqlUsername, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,0,0,16" IsEnabled="{Binding IsChecked, ElementName=SqlAuthRadio}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Hasło SQL:" VerticalAlignment="Center"/>
            <PasswordBox x:Name="SqlPasswordBox" Grid.Column="1"/>
        </Grid>

        <TextBlock Grid.Row="6" Text="Operator Subiekt GT" FontWeight="Bold" Margin="0,0,0,8"/>

        <Grid Grid.Row="7" Margin="0,0,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Operator:" VerticalAlignment="Center"/>
            <ComboBox x:Name="OperatorComboBox" Grid.Column="1" IsEditable="True" MinWidth="80"
                      Text="{Binding OperatorDisplayText, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding Operators}"
                      TextSearch.TextPath="FullName">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Content="Pobierz operatorów" Padding="6,2" Margin="6,0,0,0" Click="LoadOperatorsButton_Click"/>
        </Grid>

        <Grid Grid.Row="9" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Hasło:" VerticalAlignment="Center"/>
            <PasswordBox x:Name="OperatorPasswordBox" Grid.Column="1"/>
        </Grid>

        <StackPanel Grid.Row="10">
            <DockPanel>
                <Button Content="Wyczyść zapisane dane logowania" Padding="6,2" DockPanel.Dock="Right"
                        HorizontalAlignment="Right" Click="ClearSavedLoginButton_Click"/>
                <CheckBox Content="Zapamiętaj dane logowania" IsChecked="{Binding RememberLogin}" VerticalAlignment="Center"/>
            </DockPanel>
            <TextBlock Text="Uwaga: hasła są zapisywane jawnym tekstem w pliku na tym komputerze."
                       FontStyle="Italic" FontSize="11" Margin="20,4,0,8" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="11">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Button x:Name="ConnectButton" Content="Połącz" Padding="8,4" HorizontalAlignment="Right" Click="ConnectButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
